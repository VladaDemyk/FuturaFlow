{
  "info": {
    "name": "FuturaFlow API",
    "description": "Колекція для тестування всіх REST API ендпоінтів системи FuturaFlow.\n\nЯк використовувати:\n1. Запусти Spring Boot сервер (mvn spring-boot:run)\n2. Імпортуй цей файл у Postman (File → Import)\n3. Виконуй запити по порядку (спочатку Auth, потім решта)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string",
      "description": "JWT токен — заповнюється автоматично після логіну"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Реєстрація користувача",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Іван\",\n  \"lastName\": \"Петренко\",\n  \"email\": \"ivan@futura.com\",\n  \"password\": \"SecurePass123\",\n  \"phone\": \"+380501234567\",\n  \"dateOfBirth\": \"1995-03-15\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Вхід (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Автоматично зберігаємо токен після логіну",
                  "if (pm.response.code === 200) {",
                  "    var responseBody = pm.response.text();",
                  "    pm.collectionVariables.set('authToken', responseBody);",
                  "    console.log('Токен збережено:', responseBody);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ivan@futura.com\",\n  \"password\": \"SecurePass123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Вхід через Google (Mock)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', json.token);",
                  "    console.log('Google JWT збережено');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/google", "host": ["{{baseUrl}}"], "path": ["api", "auth", "google"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"fake-google-token-for-testing\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "BankID Mock (верифікація ФОП)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Відповідь містить токен', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.collectionVariables.set('authToken', json.token);",
                  "});",
                  "pm.test('Відповідь містить дані ФОП', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.user.ipn).to.exist;",
                  "    pm.expect(json.user.role).to.eql('FOP');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/bankid-mock", "host": ["{{baseUrl}}"], "path": ["api", "auth", "bankid-mock"] }
          },
          "response": []
        }
      ]
    },
    {
