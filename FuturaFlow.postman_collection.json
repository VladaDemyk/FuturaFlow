              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Успішне видалення (200) або не знайдено (404)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/cards/1", "host": ["{{baseUrl}}"], "path": ["api", "cards", "1"] }
          },
          "response": []
        }
      ]
