            "url": {
              "raw": "{{baseUrl}}/api/transactions/history?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions", "history"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Історія транзакцій з фільтром (profit)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
